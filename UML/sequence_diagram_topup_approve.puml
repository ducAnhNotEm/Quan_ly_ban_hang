@startuml
title Sales Management - Sequence Diagram (TopUp Create + Approve/Reject)

actor Customer
actor Admin
participant "TopUpRequestCreateView" as CreateView
participant "TopUpRequestListView" as ListView
participant "TopUpRequestApproveView" as ApproveView
participant "TopUpRequestRejectView" as RejectView
database "Customer" as CustomerDB
database "TopUpRequest" as TopUpDB
database "Wallet" as WalletDB

== Customer creates request ==
Customer -> CreateView: GET /wallet/topup/create/
alt Not authenticated
  CreateView --> Customer: Redirect /login/
else Staff account
  CreateView --> Customer: Redirect / (home)
else Customer account
  CreateView --> Customer: Render form
end

Customer -> CreateView: POST amount, note
CreateView -> CreateView: Validate amount format and value > 0
alt Invalid amount
  CreateView --> Customer: Render form + error
else Valid amount
  CreateView -> CustomerDB: load request.user.customer_profile
  alt customer_profile missing
    CreateView --> Customer: Redirect / + error
  else Found
    CreateView -> TopUpDB: create(status=PENDING, amount, note)
    TopUpDB --> CreateView: request created
    CreateView --> Customer: Redirect /wallet/ + success
  end
end

== Admin reviews requests ==
Admin -> ListView: GET /wallet/topup/requests/
ListView -> TopUpDB: all().order_by('-id')
TopUpDB --> ListView: request list
ListView --> Admin: Render list

alt Approve flow
  Admin -> ApproveView: POST /wallet/topup/requests/{id}/approve/
  ApproveView -> TopUpDB: get_object_or_404(id)
  alt status != PENDING
    ApproveView --> Admin: Redirect list + error
  else status == PENDING
    ApproveView -> WalletDB: get wallet of request.customer
    ApproveView -> WalletDB: balance += amount; save()
    ApproveView -> TopUpDB: status=APPROVED; save()
    ApproveView --> Admin: Redirect list + success
  end
else Reject flow
  Admin -> RejectView: POST /wallet/topup/requests/{id}/reject/
  RejectView -> TopUpDB: get_object_or_404(id)
  alt status != PENDING
    RejectView --> Admin: Redirect list + error
  else status == PENDING
    RejectView -> TopUpDB: status=REJECTED; save()
    RejectView --> Admin: Redirect list + success
  end
end

@enduml
